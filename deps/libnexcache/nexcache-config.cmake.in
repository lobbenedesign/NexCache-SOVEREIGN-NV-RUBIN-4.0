@PACKAGE_INIT@

set_and_check(nexcache_INCLUDEDIR "@PACKAGE_INCLUDE_INSTALL_DIR@")

IF (NOT TARGET nexcache::@nexcache_export_name@)
	INCLUDE(${CMAKE_CURRENT_LIST_DIR}/nexcache-targets.cmake)
ENDIF()

SET(nexcache_LIBRARIES nexcache::@nexcache_export_name@)
SET(nexcache_INCLUDE_DIRS ${nexcache_INCLUDEDIR})

check_required_components(nexcache)

