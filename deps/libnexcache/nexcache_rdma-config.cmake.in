@PACKAGE_INIT@

set_and_check(nexcache_rdma_INCLUDEDIR "@PACKAGE_INCLUDE_INSTALL_DIR@")

if(NOT TARGET nexcache::nexcache_rdma)
	INCLUDE(${CMAKE_CURRENT_LIST_DIR}/nexcache_rdma-targets.cmake)
endif()

set(nexcache_rdma_LIBRARIES nexcache::nexcache_rdma)
set(nexcache_rdma_INCLUDE_DIRS ${nexcache_rdma_INCLUDEDIR})

check_required_components(nexcache_rdma)

